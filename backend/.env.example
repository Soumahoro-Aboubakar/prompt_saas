# ============================================================
# Backend — Variables d'environnement
# ============================================================

# Environnement
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# ============================================================
# Stockage Cloud — Sélecteur de provider
# Valeur : "cloudflare" ou "backblaze"
# ============================================================
STORAGE_PROVIDER=cloudflare

# --- Cloudflare R2 ---
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_R2_BUCKET=your-bucket-name
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
# URL publique R2 custom domain (optionnel, recommandé)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# --- Backblaze B2 ---
BACKBLAZE_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_REGION=us-west-004
BACKBLAZE_KEY_ID=your_backblaze_key_id
BACKBLAZE_APP_KEY=your_backblaze_app_key
BACKBLAZE_BUCKET_NAME=your-bucket-name
# URL publique B2 (optionnel)
BACKBLAZE_PUBLIC_URL=https://f004.backblazeb2.com/file/your-bucket-name

# ============================================================
# Email — Brevo (ex Sendinblue)
# ============================================================
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=noreply@eprompt.site
FROM_NAME=PromptAcademy

# ============================================================
# OAuth
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
CLIENT_URL=http://localhost:5173

# ============================================================
# AI APIs (optionnel — pour futurs fonctionnalités)
# ============================================================
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
